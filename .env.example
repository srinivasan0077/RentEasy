# Supabase Configuration
# Get these from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Without these, RentEasy runs in local mode (localStorage)

# Razorpay Configuration (for subscription payments)
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Use Test keys for development, Live keys for production
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# Note: RAZORPAY_KEY_SECRET goes in Supabase Edge Function Secrets
# (never expose it on the frontend)
# Set it via: Supabase Dashboard → Edge Functions → Secrets
#   RAZORPAY_KEY_ID=rzp_test_...
#   RAZORPAY_KEY_SECRET=your_secret_here

# Admin Portal — only this email can access the admin page
VITE_ADMIN_EMAIL=your-admin-email@example.com
